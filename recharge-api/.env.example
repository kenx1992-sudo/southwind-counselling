# 環境變數配置
# 複製此文件為 .env 並填入實際值

# MongoDB 連接字符串
# 從 MongoDB Atlas 獲取：https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/southwind?retryWrites=true&w=majority

# Stripe 配置
# 從 Stripe Dashboard 獲取：https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 管理員令牌（用於訪問管理後台）
ADMIN_TOKEN=your_secure_random_token_here

# 前端 URL（用於支付成功後跳轉）
FRONTEND_URL=https://southwind-counselling.vercel.app

# 服務器端口（Railway 會自動設置）
PORT=3000
